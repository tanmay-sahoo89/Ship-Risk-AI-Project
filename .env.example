# =====================================================
# Ship Risk AI - Environment Variables Template
# =====================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git

# =====================================================
# MongoDB/Database Configuration (if using)
# =====================================================
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/database_name
DATABASE_NAME=ship_risk_ai

# =====================================================
# Firebase Configuration
# =====================================================
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-app.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456
FIREBASE_DATABASE_URL=https://your-app.firebaseio.com

# =====================================================
# Service Account Key (for Firebase Admin SDK)
# =====================================================
# Use a path to serviceAccountKey.json file or set it directly
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# =====================================================
# API Server Configuration
# =====================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# =====================================================
# Frontend Configuration
# =====================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# =====================================================
# ML Model Configuration
# =====================================================
MODEL_PATH=./artifacts/best_model.pkl
SCALER_PATH=./artifacts/scaler.pkl
LABEL_ENCODERS_PATH=./artifacts/label_encoders.pkl

# =====================================================
# Data Configuration
# =====================================================
DATA_PATH=./data
PROCESSED_DATA_PATH=./artifacts/processed_data.csv

# =====================================================
# Logging Configuration
# =====================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =====================================================
# Environment
# =====================================================
ENVIRONMENT=development
# development | staging | production

# =====================================================
# CORS Configuration (for API)
# =====================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# =====================================================
# Security
# =====================================================
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =====================================================
# External API Keys (All Free Tier)
# =====================================================
# Weather — Open-Meteo (free, unlimited, no auth needed)
OPEN_METEO_API_URL=https://api.open-meteo.com/v1/forecast

# Routing — OpenRouteService (free tier: 40 req/min, register at openrouteservice.org)
OPENROUTESERVICE_API_KEY=

# Aircraft Tracking — OpenSky Network (free, no auth needed, 400 req/hr)
OPENSKY_API_URL=https://opensky-network.org/api

# =====================================================
# AI Configuration (Local — Ollama)
# =====================================================
# Install Ollama: https://ollama.ai | Run: ollama serve | Pull: ollama pull mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest
